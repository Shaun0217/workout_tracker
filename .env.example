# Copy to .env.local and fill in from your Supabase project:
#   Supabase dashboard → Project Settings → API
#
# The anon key is safe to expose in the client because Row Level Security
# is enabled on every table. NEVER put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Single-user auto-login. The app signs in with these on load — no login
# screen, no email. Create this user once in the Supabase dashboard:
#   Authentication → Users → Add user → set a password → check "Auto Confirm".
# Then set the same values here. Note: these get bundled into the client, so
# they are not truly secret — fine for a personal app, but don't reuse a
# password you use elsewhere.
VITE_APP_AUTH_EMAIL=you@example.com
VITE_APP_AUTH_PASSWORD=choose-a-password
